        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Agent Execution Times",
      "description": "Average execution duration per agent type",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(rate(agentflow_agent_execution_duration_seconds_sum{job=\"agentflow-backend\"}[5m])) by (agent_type) / avg(rate(agentflow_agent_execution_duration_seconds_count{job=\"agentflow-backend\"}[5m])) by (agent_type)",
          "legendFormat": "{{agent_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
