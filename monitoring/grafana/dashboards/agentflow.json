      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(agentflow_llm_tokens_total{job=\"agentflow-backend\"}[5m])) by (agent_type)",
          "legendFormat": "{{agent_type}}",
          "refId": "A"
        }
      ]
